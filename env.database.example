# ========================================
# HOTEL PMS - VARIABLES DE ENTORNO BASE DE DATOS
# ========================================
# COPIA ESTE ARCHIVO A .env Y CONFIGURA TUS VALORES

# ========================================
# BASE DE DATOS (CRÍTICO)
# ========================================

# URL de conexión principal para Prisma
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/hotel_pms"

# Configuración detallada para Connection Pool
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=hotel_pms
DATABASE_USER=postgres
DATABASE_PASSWORD=your_password
DATABASE_SSL=false

# Configuración del Pool de Conexiones
DATABASE_MAX_CONNECTIONS=20
DATABASE_IDLE_TIMEOUT=30000
DATABASE_CONNECTION_TIMEOUT=10000
DATABASE_STATEMENT_TIMEOUT=30000
DATABASE_QUERY_TIMEOUT=30000

# ========================================
# AUTENTICACIÓN (CRÍTICO)
# ========================================

# NextAuth.js Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_here_min_32_chars

# JWT Configuration
JWT_SECRET=your_jwt_secret_here_min_32_chars

# ========================================
# REDIS (CRÍTICO PARA CACHE Y COLAS)
# ========================================

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0
REDIS_QUEUE_DB=1

# ========================================
# CONFIGURACIÓN DEL HOTEL
# ========================================

# Hotel Information
HOTEL_NAME="Hotel Paseo Las Mercedes"
HOTEL_ADDRESS="Dirección del Hotel"
HOTEL_PHONE="+1234567890"
HOTEL_EMAIL="info@hotel.com"
HOTEL_CURRENCY=USD
HOTEL_TIMEZONE=America/Caracas

# ========================================
# CONFIGURACIÓN DE DESARROLLO
# ========================================

# Environment
NODE_ENV=development

# Next.js Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# ========================================
# NOTAS IMPORTANTES
# ========================================

# 1. COPIA ESTE ARCHIVO A .env
# 2. CONFIGURA TODAS LAS VARIABLES REQUERIDAS
# 3. NUNCA COMMITEES .env AL REPOSITORIO
# 4. PARA PRODUCCIÓN, USA VARIABLES DE ENTORNO SEGURAS
# 5. VERIFICA QUE POSTGRESQL Y REDIS ESTÉN EJECUTÁNDOSE

