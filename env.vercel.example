# 🚀 VARIABLES DE ENTORNO PARA VERCEL + SUPABASE
# Copia este archivo y reemplaza los valores con tus credenciales reales

# ========================================
# 🔐 BASE DE DATOS (SUPABASE)
# ========================================
DATABASE_URL="postgresql://postgres:[TU-PASSWORD]@db.[TU-PROJECT-REF].supabase.co:5432/postgres"

# ========================================
# 🔒 AUTENTICACIÓN
# ========================================
NEXTAUTH_SECRET="hotel_pms_2024_production_secret_key_secure_32"
JWT_SECRET="hotel_pms_jwt_production_secret_2024_secure_key"

# ========================================
# 🌐 URLs Y ENTORNO
# ========================================
NEXTAUTH_URL="https://[TU-APP-NAME].vercel.app"
NEXT_PUBLIC_APP_URL="https://[TU-APP-NAME].vercel.app"
NODE_ENV="production"

# ========================================
# 🗄️ PRISMA
# ========================================
PRISMA_GENERATE_DATAPROXY="true"

# ========================================
# 🏨 CONFIGURACIÓN DEL HOTEL (OPCIONAL)
# ========================================
HOTEL_NAME="Hotel Paseo Las Mercedes"
HOTEL_ADDRESS="Dirección del Hotel"
HOTEL_PHONE="+1234567890"
HOTEL_EMAIL="info@hotel.com"
HOTEL_CURRENCY="USD"
HOTEL_TIMEZONE="America/Caracas"

# ========================================
# 📧 COMUNICACIONES (OPCIONAL)
# ========================================
SENDGRID_API_KEY="[TU-API-KEY-SENDGRID]"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="[TU-EMAIL]"
SMTP_PASS="[TU-PASSWORD-APP]"

# ========================================
# 💳 PAGOS (OPCIONAL)
# ========================================
STRIPE_SECRET_KEY="[TU-STRIPE-SECRET-KEY]"
STRIPE_PUBLISHABLE_KEY="[TU-STRIPE-PUBLISHABLE-KEY]"
MERCADOPAGO_ACCESS_TOKEN="[TU-MERCADOPAGO-TOKEN]"
PAYPAL_CLIENT_ID="[TU-PAYPAL-CLIENT-ID]"
PAYPAL_CLIENT_SECRET="[TU-PAYPAL-CLIENT-SECRET]"

# ========================================
# 📊 MONITOREO (OPCIONAL)
# ========================================
SENTRY_DSN="[TU-SENTRY-DSN]"
NEXT_PUBLIC_SENTRY_DSN="[TU-SENTRY-DSN-PUBLIC]"

# ========================================
# 🔍 ANALYTICS (OPCIONAL)
# ========================================
NEXT_PUBLIC_GA_ID="[TU-GOOGLE-ANALYTICS-ID]"
NEXT_PUBLIC_MIXPANEL_TOKEN="[TU-MIXPANEL-TOKEN]"

# ========================================
# 📱 PWA (OPCIONAL)
# ========================================
NEXT_PUBLIC_PWA_ENABLED="true"
NEXT_PUBLIC_PWA_NAME="Hotel PMS"
NEXT_PUBLIC_PWA_SHORT_NAME="Hotel PMS"
NEXT_PUBLIC_PWA_DESCRIPTION="Sistema de gestión hotelera"

# ========================================
# 🚨 ALERTAS Y NOTIFICACIONES (OPCIONAL)
# ========================================
DISCORD_WEBHOOK_URL="[TU-DISCORD-WEBHOOK]"
SLACK_WEBHOOK_URL="[TU-SLACK-WEBHOOK]"
TELEGRAM_BOT_TOKEN="[TU-TELEGRAM-BOT-TOKEN]"
TELEGRAM_CHAT_ID="[TU-TELEGRAM-CHAT-ID]"

# ========================================
# 📋 INSTRUCCIONES DE USO
# ========================================
# 1. Copia este archivo a tu proyecto
# 2. Reemplaza [VALORES] con tus credenciales reales
# 3. En Vercel, ve a Settings → Environment Variables
# 4. Agrega cada variable UNA POR UNA
# 5. Asegúrate de que estén marcadas para "Production"
# 6. Haz redeploy después de configurar todas las variables

# ========================================
# ⚠️  IMPORTANTE
# ========================================
# - NUNCA subas este archivo a GitHub
# - Mantén tus credenciales seguras
# - Usa contraseñas fuertes y únicas
# - Rota las claves regularmente
# - Monitorea el uso de tu aplicación
