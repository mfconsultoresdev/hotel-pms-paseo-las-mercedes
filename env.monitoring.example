# ========================================
# MONITORING & OBSERVABILITY CONFIGURATION
# ========================================

# Sentry Configuration
SENTRY_DSN=your_sentry_dsn_here
NEXT_PUBLIC_SENTRY_DSN=your_public_sentry_dsn_here
SENTRY_ORG=your_organization
SENTRY_PROJECT=hotel-pms
SENTRY_AUTH_TOKEN=your_sentry_auth_token

# Logging Configuration
LOG_LEVEL=info
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=your_elasticsearch_password

# Monitoring Configuration
ENABLE_HEALTH_CHECKS=true
HEALTH_CHECK_INTERVAL=30000
ENABLE_METRICS=true
ENABLE_ALERTS=true

# Alert Configuration
ADMIN_EMAILS=admin@hotel.com,manager@hotel.com
SLACK_WEBHOOK_URL=your_slack_webhook_url
ALERT_WEBHOOK_URL=your_alert_webhook_url
ALERT_WEBHOOK_TOKEN=your_webhook_token

# Performance Monitoring
ENABLE_PERFORMANCE_MONITORING=true
PERFORMANCE_THRESHOLD_MS=2000
ERROR_RATE_THRESHOLD=0.05

# Database Monitoring
DB_CONNECTION_TIMEOUT=5000
DB_QUERY_TIMEOUT=10000

# External Services Monitoring
PAYMENT_GATEWAY_TIMEOUT=10000
OTA_INTEGRATION_TIMEOUT=15000
EMAIL_SERVICE_TIMEOUT=5000

# Metrics Retention
METRICS_RETENTION_DAYS=90
LOG_RETENTION_DAYS=30
ALERT_RETENTION_DAYS=7

# Health Check Thresholds
MEMORY_USAGE_THRESHOLD=90
CPU_USAGE_THRESHOLD=80
DISK_USAGE_THRESHOLD=85

# Monitoring Dashboard
MONITORING_DASHBOARD_ENABLED=true
MONITORING_DASHBOARD_REFRESH_INTERVAL=30000
MONITORING_DASHBOARD_AUTO_REFRESH=true

# ========================================
# INTEGRATION CONFIGURATION
# ========================================

# Prometheus Configuration
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
PROMETHEUS_PATH=/metrics

# Grafana Configuration (if using)
GRAFANA_ENABLED=false
GRAFANA_URL=http://localhost:3001
GRAFANA_API_KEY=your_grafana_api_key

# Jaeger Configuration (for distributed tracing)
JAEGER_ENABLED=false
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831

# Redis Configuration (for caching and session storage)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# ========================================
# SECURITY & COMPLIANCE
# ========================================

# Monitoring Security
MONITORING_AUTH_ENABLED=true
MONITORING_AUTH_TOKEN=your_monitoring_auth_token
MONITORING_IP_WHITELIST=127.0.0.1,::1

# Data Privacy
LOG_PII_FILTERING=true
LOG_SANITIZATION=true
LOG_ENCRYPTION=false

# Compliance
GDPR_COMPLIANCE_ENABLED=true
DATA_RETENTION_ENFORCEMENT=true
AUDIT_LOGGING_ENABLED=true

# ========================================
# DEVELOPMENT & TESTING
# ========================================

# Development Mode
NODE_ENV=development
ENABLE_DEBUG_LOGGING=true
ENABLE_VERBOSE_MONITORING=true

# Testing Configuration
ENABLE_TEST_METRICS=false
MOCK_EXTERNAL_SERVICES=true
TEST_ALERT_CHANNELS=false

# ========================================
# DEPLOYMENT & SCALING
# ========================================

# Deployment Environment
DEPLOYMENT_ENVIRONMENT=development
APP_VERSION=1.0.0
BUILD_NUMBER=001

# Scaling Configuration
ENABLE_AUTO_SCALING=false
MAX_CONCURRENT_REQUESTS=1000
REQUEST_QUEUE_SIZE=100

# Load Balancing
ENABLE_LOAD_BALANCING=false
HEALTH_CHECK_ENDPOINT=/api/monitoring/health
LOAD_BALANCER_TIMEOUT=5000

