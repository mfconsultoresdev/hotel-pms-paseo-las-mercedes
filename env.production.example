# ========================================
# HOTEL PMS - VARIABLES DE ENTORNO PRODUCCIÓN
# ========================================
# COPIA ESTE ARCHIVO A .env.local PARA PRODUCCIÓN

# ========================================
# BASE DE DATOS PRODUCCIÓN
# ========================================

# Para Railway, Supabase, o Neon (PostgreSQL gratuito)
DATABASE_URL="postgresql://username:password@host:port/database"

# Configuración detallada
DATABASE_HOST=your_db_host
DATABASE_PORT=5432
DATABASE_NAME=your_db_name
DATABASE_USER=your_db_user
DATABASE_PASSWORD=your_db_password
DATABASE_SSL=true

# ========================================
# AUTENTICACIÓN
# ========================================

# NextAuth.js Configuration
NEXTAUTH_URL=https://your-app.vercel.app
NEXTAUTH_SECRET=your_production_secret_here_min_32_chars

# JWT Configuration
JWT_SECRET=your_production_jwt_secret_here_min_32_chars

# ========================================
# REDIS (OPCIONAL)
# ========================================

# Para Railway, Upstash, o Redis Cloud
REDIS_URL=redis://username:password@host:port
REDIS_HOST=your_redis_host
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# ========================================
# CONFIGURACIÓN DEL HOTEL
# ========================================

HOTEL_NAME="Hotel Paseo Las Mercedes"
HOTEL_ADDRESS="Dirección del Hotel"
HOTEL_PHONE="+1234567890"
HOTEL_EMAIL="info@hotel.com"
HOTEL_CURRENCY=USD
HOTEL_TIMEZONE=America/Caracas

# ========================================
# CONFIGURACIÓN DE PRODUCCIÓN
# ========================================

NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
NEXT_PUBLIC_API_URL=https://your-app.vercel.app/api

# ========================================
# MONITOREO (OPCIONAL)
# ========================================

# Sentry para monitoreo de errores
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here

# ========================================
# NOTAS IMPORTANTES
# ========================================

# 1. NUNCA uses las credenciales de desarrollo en producción
# 2. Genera secrets únicos y seguros para producción
# 3. Usa HTTPS en todas las URLs
# 4. Configura variables de entorno en tu plataforma de deploy
# 5. Verifica que la base de datos esté accesible desde internet



